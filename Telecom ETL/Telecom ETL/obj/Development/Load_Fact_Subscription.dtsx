                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">#{Package\Data Flow Task\OLE DB Source.Outputs[OLE DB Source Output].Columns[SubStatus]} == "Churned" ? (DT_BOOL)1 : (DT_BOOL)0</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">SubStatus == "Churned" ? (DT_BOOL)1 : (DT_BOOL)0</property>
